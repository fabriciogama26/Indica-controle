{
  "name": "saas-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbopack": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:link": "npx supabase link --project-ref lcusxnhhrjosxqgiphgp",
    "db:check-link": "powershell -ExecutionPolicy Bypass -File scripts/supabase-check-link.ps1",
    "db:status": "npm run db:check-link && npx supabase projects list",
    "db:migration-list": "npm run db:check-link && npx supabase migration list --linked",
    "db:lint": "npm run db:check-link && npx supabase db lint --linked",
    "db:security-check": "powershell -ExecutionPolicy Bypass -File scripts/check-security-definer.ps1",
    "db:security-check-live": "npm run db:check-link && npx supabase db query --file scripts/check-security-definer-live.sql --linked"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5"
  }
}
